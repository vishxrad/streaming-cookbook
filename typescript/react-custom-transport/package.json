{
  "name": "@examples/ui-react-transport",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter . run --parallel \"/^dev:(client|server)$/\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=../../.env --clear-screen=false src/app.ts",
    "build:internal": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@hono/node-server": "^2.0.4",
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "^1.3.4",
    "@langchain/openai": "^1.4.7",
    "@langchain/protocol": "^0.0.16",
    "@langchain/react": "^1.0.15",
    "hono": "^4.12.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
{
  "name": "@examples/ui-angular",
  "version": "0.0.21",
  "scripts": {
    "dev": "pnpm --filter . run --parallel \"/^dev:(client|server)$/\"",
    "dev:client": "NG_CLI_ANALYTICS=false ng serve",
    "dev:server": "langgraphjs dev --no-browser",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@langchain/angular": "^1.0.1",
    "@langchain/core": "1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-sdk": "^1.9.1",
    "@langchain/openai": "^1.4.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.2",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@langchain/langgraph-cli": "^1.2.1",
    "typescript": "~6.0.3"
  }
}

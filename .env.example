# Copy this file to `.env` at the repository root, then fill in the values.
# All TypeScript examples load this shared root env file.

# Anthropic API key
ANTHROPIC_API_KEY=<sk-...>
# OpenAI API key
OPENAI_API_KEY=<sk-...>

# OpenUI dashboard data sources. The dashboard defaults to deterministic
# mock data. Set individual providers to live after configuring them.
DATA_MODE=mock

# Stripe
# STRIPE_DATA_MODE=live
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd

# PostHog personal key with Query Read access
# POSTHOG_DATA_MODE=live
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com
POSTHOG_FUNNEL_EVENTS=$pageview,signup,dashboard_created,invite_sent,billing_upgraded
POSTHOG_FUNNEL_LABELS=Visited landing page,Signed up,Created first dashboard,Invited a teammate,Upgraded to paid

# GitHub: auto prefers GITHUB_TOKEN/GH_TOKEN, then authenticated `gh`
# GITHUB_DATA_MODE=live
GITHUB_TRANSPORT=auto
GITHUB_OWNER=
GITHUB_TOKEN=

# Google Calendar: auto prefers OAuth credentials, then authenticated `gog`
# GOOGLE_CALENDAR_DATA_MODE=live
GOOGLE_CALENDAR_TRANSPORT=auto
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIME_ZONE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOG_ACCOUNT=
CALENDAR_WORKDAY_START=09:00
CALENDAR_WORKDAY_END=18:00
